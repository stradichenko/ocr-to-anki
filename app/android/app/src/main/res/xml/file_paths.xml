<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Downloaded APKs are written to getExternalCacheDir()/updates -->
    <external-cache-path name="updates" path="updates/" />
    <!-- Fallback: internal cache directory -->
    <cache-path name="cache_updates" path="updates/" />
</paths>
